# URL ของ Python vision service (best.pt) สำหรับอ่านเลขมิเตอร์
VISION_SERVICE_URL=http://127.0.0.1:8000

# ฐานข้อมูล MySQL (ใช้โดย npm run seed:admin)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=water-bill-db

# แอดมินเริ่มต้นที่ npm run seed:admin จะสร้างให้ (ค่า default ตรงกับบัญชีทดสอบใน README)
SEED_ADMIN_EMAIL=somying@example.com
SEED_ADMIN_PASSWORD=password123
SEED_ADMIN_FNAME=สมหญิง
SEED_ADMIN_LNAME=ใจดี

# 🔐 กุญแจเซ็น JWT — สร้างค่าของตัวเองด้วย:
#    node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ⚠️ ห้าม commit ค่าจริงลง git และห้ามใช้ค่าเดียวกันระหว่าง dev กับ production
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มของคุณเอง
JWT_EXPIRES_IN=1d
